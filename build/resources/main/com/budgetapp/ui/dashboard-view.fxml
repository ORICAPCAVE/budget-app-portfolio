<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.budgetapp.ui.DashboardController">
    <top>
        <VBox spacing="8.0" style="-fx-padding: 16; -fx-background-color: #1d3557;">
            <Label text="Budget App Starter" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" />
            <Label text="Desktop JavaFX foundation for budgeting, expenses, and debt payoff planning."
                   style="-fx-text-fill: #dbe7f0;" />
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
        <content>
        <VBox spacing="16.0" style="-fx-padding: 18;">
            <GridPane hgap="14.0" vgap="14.0">
                <padding>
                    <Insets top="8" right="8" bottom="8" left="8"/>
                </padding>

                <VBox spacing="4.0" style="-fx-background-color: #f1f5f9; -fx-padding: 14; -fx-background-radius: 10;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Monthly Income" style="-fx-font-weight: bold;"/>
                    <Label fx:id="incomeValueLabel" text="0.00" style="-fx-font-size: 20px;"/>
                </VBox>

                <VBox spacing="4.0" style="-fx-background-color: #f1f5f9; -fx-padding: 14; -fx-background-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Average Monthly Expenses" style="-fx-font-weight: bold;"/>
                    <Label fx:id="expensesValueLabel" text="0.00" style="-fx-font-size: 20px;"/>
                </VBox>

                <VBox spacing="4.0" style="-fx-background-color: #f1f5f9; -fx-padding: 14; -fx-background-radius: 10;" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="Debt Payments" style="-fx-font-weight: bold;"/>
                    <Label fx:id="debtPaymentsValueLabel" text="0.00" style="-fx-font-size: 20px;"/>
                </VBox>

                <VBox spacing="4.0"
                      style="-fx-background-color: #f1f5f9; -fx-padding: 14; -fx-background-radius: 10;"
                      GridPane.columnIndex="1"
                      GridPane.rowIndex="1">

                    <Label text="Remaining Cash" style="-fx-font-weight: bold;"/>
                    <Label fx:id="remainingCashValueLabel"
                           text="0.00"
                           style="-fx-font-size: 20px;"/>
                </VBox>
            </GridPane>

            <VBox spacing="8.0" style="-fx-background-color: #f8fafc; -fx-padding: 16; -fx-border-color: #d9e2ec; -fx-border-radius: 10; -fx-background-radius: 10;">
                <Label text="Expenses" style="-fx-font-weight: bold;"/>
                <HBox spacing="10" alignment="BOTTOM_LEFT">

                    <VBox spacing="4">
                        <Label text=" "/>
                        <Button text="Add Expense" onAction="#handleOpenExpenseWindow"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text=" "/>
                        <Button text="Delete Selected Expense" onAction="#handleDeleteExpense"/>
                    </VBox>
                </HBox>

                <TableView fx:id="expenseTable">
                    <columns>
                        <TableColumn fx:id="nameColumn" text="Name"/>
                        <TableColumn fx:id="amountColumn" text="Amount"/>
                        <TableColumn fx:id="recurrenceColumn" text="Recurrence"/>
                        <TableColumn fx:id="expenseDueDateColumn" text="Next Due Date"/>
                        <TableColumn fx:id="expenseCategoryColumn" text="Category"/>
                    </columns>
                </TableView>
            </VBox>
            <VBox spacing="8.0" style="-fx-background-color: #f8fafc; -fx-padding: 16;">
                <Label text="Income" style="-fx-font-weight: bold;"/>
                <HBox spacing="10" alignment="BOTTOM_LEFT">

                    <VBox spacing="4">
                        <Label text=" "/>
                        <Button text="Add Income" onAction="#handleOpenIncomeWindow"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text=" "/>
                        <Button text="Delete Selected Income" onAction="#handleDeleteIncome"/>
                    </VBox>
                </HBox>
                <TableView fx:id="incomeTable">
                    <columns>
                        <TableColumn fx:id="incomeSourceColumn" text="Source"/>
                        <TableColumn fx:id="incomeAmountColumn" text="Amount"/>
                        <TableColumn fx:id="incomeRecurrenceColumn" text="Recurrence"/>
                        <TableColumn fx:id="incomeReceivedDateColumn" text="Date"  />
                    </columns>
                </TableView>
            </VBox>
            <VBox spacing="8.0" style="-fx-background-color: #f8fafc; -fx-padding: 16;">
                <Label text="Debts" style="-fx-font-weight: bold;"/>
                <HBox spacing="10" alignment="BOTTOM_LEFT">

                    <VBox spacing="4">
                        <Label text=" "/>
                        <Button text="Add Debt" onAction="#handleOpenDebtWindow"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text=" "/>
                        <Button text="Delete Selected Debt" onAction="#handleDeleteDebt"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text=" "/>
                        <Button text="Run Payoff Report" onAction="#handleRunPayoffReport"/>
                    </VBox>
                    <VBox spacing="6" style="-fx-padding: 10; -fx-background-color: #f4f4f4; -fx-border-color: #cccccc;">

                        <Label text="Payoff Report" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <Label fx:id="payoffDebtNameLabel"
                               text="Debt Name"
                               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <Label fx:id="payoffMonthsLabel" text="Select a debt and run payoff report."/>
                        <Label fx:id="payoffInterestLabel" text=""/>
                        <Label fx:id="negativeAmortizationLabel" text=""/>
                        <Label fx:id="suggestedPaymentLabel" text=""/>

                    </VBox>
                </HBox>

                <TableView fx:id="debtTable">
                <columns>
                    <TableColumn fx:id="debtNameColumn" text="Debt Name"/>
                    <TableColumn fx:id="debtAmountColumn" text="Balance"/>
                    <TableColumn fx:id="debtRateColumn" text="Interest Rate"/>
                    <TableColumn fx:id="debtMinPaymentColumn" text="Min Payment"/>
                    <TableColumn fx:id="debtRecurrenceColumn" text="Frequency"/>
                    <TableColumn fx:id="debtMonthsColumn" text="Months" />
                    <TableColumn fx:id="debtInterestPaidColumn" text="Total Interest" />
                    <TableColumn fx:id="debtNegativeAmColumn" text="Status" />

                </columns>
            </TableView>
        </VBox>
        </VBox>
        </content>
        </ScrollPane>
    </center>

</BorderPane>
